{
  "name": "pairwith",
  "version": "0.1.0",
  "description": "Install developer pair programming profiles for Claude Code, Cursor, and GitHub Copilot",
  "type": "module",
  "bin": {
    "pairwith": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "commander": "^12.0.0",
    "gray-matter": "^4.0.3",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai",
    "pair-programming",
    "profiles",
    "claude",
    "claude-code",
    "copilot",
    "cursor",
    "developer-tools"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/merencia/pairwith.git"
  },
  "homepage": "https://github.com/merencia/pairwith#readme",
  "bugs": {
    "url": "https://github.com/merencia/pairwith/issues"
  }
}
